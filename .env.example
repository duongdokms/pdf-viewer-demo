# Apryse Configuration
# Copy this file to .env.local and add your actual values

# Apryse WebViewer License Key
# Get a trial key from: https://dev.apryse.com/
REACT_APP_APRYSE_LICENSE_KEY=

# PDF Document Path (relative to public folder)
REACT_APP_INITIAL_PDF=sample.pdf

# Optional: API endpoint for form field recognition
# REACT_APP_FORM_RECOGNITION_API=https://your-api.com/analyze
